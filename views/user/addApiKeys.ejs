<% layout("layout/boilerplate.ejs") %>
<body>
  <div class="cover">
    <%- include("../includes/flash.ejs") %>
    <div class="signup-container">
      <div class="signup-header">
        <h1>Welcome to AI Chat</h1>
        <p>Add or update your API keys</p>
      </div>

      <form action="/addapikey" method="POST" class="needs-validation" novalidate>
        <div class="mb-3">
          <label class="form-label">Gemini Model</label>
          <input type="text" name="models[gemini]" value="<%= apiConfig?.gemini?.model || 'gemini-2.5-flash' %>" class="form-control">
          <input type="text" name="apikeys[gemini]" value="<%= apiConfig?.gemini?.key || '' %>" placeholder="Gemini API Key" class="form-control mt-2">
        </div>

        <div class="mb-3">
          <label class="form-label">ChatGPT Model</label>
          <input type="text" name="models[openai]" value="<%= apiConfig?.openai?.model || 'gpt-4o-mini' %>" class="form-control">
          <input type="text" name="apikeys[openai]" value="<%= apiConfig?.openai?.key || '' %>" placeholder="OpenAI API Key" class="form-control mt-2">
        </div>

        <div class="mb-3">
          <label class="form-label">DeepSeek Model</label>
          <input type="text" name="models[deepseek]" value="<%= apiConfig?.deepseek?.model || 'deepseek-chat' %>" class="form-control">
          <input type="text" name="apikeys[deepseek]" value="<%= apiConfig?.deepseek?.key || '' %>" placeholder="DeepSeek API Key" class="form-control mt-2">
        </div>

        <div class="d-flex gap-2">
          <button type="submit" class="btn btn-primary">Save & Continue</button>
          <a id="demoBtn" href="/multiGPT" class="btn btn-outline-secondary">Demo</a>
        </div>
      </form>
    </div>
  </div>
</body>
