async function getGiminiStreamResponse(
    context,
    message,
    onToken
) {
    try {
        const response = await fetch("/api/gimini/stream", {
            method: "POST",
            headers: {
                "Content-Type": "application/json",
            },
            body: JSON.stringify({ context, message, user }),
        });

        if (!response.ok || !response.body) {
            const errText = await response.text().catch(() => "");
            const msg = errText ? `Error: ${errText}` : `Error: HTTP ${response.status}`;
            onToken(msg);
            return msg;
        }

        const reader = response.body.getReader();
        const decoder = new TextDecoder();

        let buffer = "";
        let fullText = "";

        while (true) {
            const { value, done } = await reader.read();
            if (done) break;

            buffer += decoder.decode(value, { stream: true });
            const events = buffer.split("\n\n");
            buffer = events.pop() || "";

            for (const evt of events) {
                const line = evt
                    .split("\n")
                    .find(l => l.startsWith("data:"));

                if (!line) continue;

                const payload = line.replace(/^data:\s*/, "").trim();

                if (payload === "[DONE]") {
                    return fullText;
                }

                const data = JSON.parse(payload);
                if (data.error) {
                    fullText = `Error: ${data.error}`;
                    onToken(fullText);
                    return fullText;
                }
                if (data.token) {
                    fullText += data.token;
                    onToken(fullText);
                }
            }
        }

        return fullText;

    } catch (error) {
        console.error("Gemini stream error:", error);
        const msg = `Error: ${error.message || error}`;
        onToken(msg);
        return msg;
    }
}

async function getDeepSeekStreamResponse(context, message, onToken) {
    try {
        const resp = await fetch("/api/deepseek/stream", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ context, message }),
        });

        if (!resp.ok || !resp.body) {
            const errText = await resp.text().catch(() => "");
            const msg = errText ? `Error: ${errText}` : `Error: HTTP ${resp.status}`;
            onToken(msg);
            return msg;
        }

        const reader = resp.body.getReader();
        const decoder = new TextDecoder();
        let buffer = "";
        let fullText = "";

        while (true) {
            const { value, done } = await reader.read();
            if (done) break;

            buffer += decoder.decode(value, { stream: true });
            const events = buffer.split("\n\n");
            buffer = events.pop() || "";

            for (const evt of events) {
                const line = evt.split("\n").find((l) => l.startsWith("data:"));
                if (!line) continue;

                const payload = line.replace(/^data:\s*/, "").trim();
                if (payload === "[DONE]") return fullText;

                const data = JSON.parse(payload);
                if (data.error) {
                    fullText = `Error: ${data.error}`;
                    onToken(fullText);
                    return fullText;
                }
                if (data.token) {
                    fullText += data.token;
                    onToken(fullText);
                }
            }
        }

        return fullText;
    } catch (error) {
        console.error("DeepSeek stream error:", error.message);
        const msg = `Error: ${error.message}`;
        onToken(msg);
        return msg;
    }
}
async function getDeepSeekResponse(context, message, isTitle) {
    try {
        const resp = await fetch("/api/deepseek", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ context, message, isTitle }),
        });

        if (!resp.ok) {
            throw new Error(`HTTP Error: ${resp.status}`);
