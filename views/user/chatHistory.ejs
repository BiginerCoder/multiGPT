async function getChatHistory(matchedChat) {
  try {
    if (!matchedChat?.chats) {
      console.error("Chat not found");
      return;
    }

    const fragment = document.createDocumentFragment(); // 🚀 Faster DOM handling

    for (let chat of matchedChat.chats) {

      // USER MESSAGE
      const userBox = createChatBox(
        `<div class="user-chat-area">${chat.message}</div>`,
        "user-chat-box"
      );
      fragment.appendChild(userBox);

      // AI MESSAGE (if exists)
      if (chat.response) {
        const formattedAI = formatResponseToHTML(chat.response);

        const aiBox = createChatBox(
          `<div class="ai-chat-area">${formattedAI}</div>`,
          "ai-chat-box"
        );

        fragment.appendChild(aiBox);

        // ❌ Don't animate history messages
        // responseChatBox(aiBox, formattedAI); 
      }
    }

    chatSection.appendChild(fragment);

    // smooth scroll
    chatContainer.scrollTo({
      top: chatContainer.scrollHeight,
      behavior: "smooth"
    });

  } catch (err) {
    console.error("Error in getChatHistory:", err);
  }
}
