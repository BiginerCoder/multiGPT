function imgChangClass(action) {
    if (action === "upload") {
        imgbtn.classList.remove("xchoose");
        imgbtn.classList.add("xchoosebtn");
    } else if (action === "submit") {
        imgbtn.classList.remove("xchoosebtn");
        imgbtn.classList.add("xchoose");
    }
}
