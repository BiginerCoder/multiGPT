async function responseChatBox(aiChatBox, response, model) {
    const text = aiChatBox.querySelector(".ai-chat-area"); // Select existing chat area

    if (!text) {
        console.error(`Chat area not found for ${model}`);
        return;
    }

    text.innerHTML = ""; // Clear loading animation

    // Add model name heading
    const heading = document.createElement("h4");
    heading.textContent = model;
    text.appendChild(heading);

    // Add AI response
    const responseDiv = document.createElement("div");
    responseDiv.innerHTML = response;
    text.appendChild(responseDiv);

    // Auto-scroll to bottom
    chatContainer.scrollTo({ top: chatContainer.scrollHeight, behavior: "smooth" });
}

function startStreamingChatBox(aiChatBox, model) {
    const text = aiChatBox.querySelector(".ai-chat-area");
    if (!text) return null;

    text.innerHTML = "";
    const heading = document.createElement("h4");
    heading.textContent = model;
    text.appendChild(heading);

    const loading = document.createElement("div");
    loading.className = "stream-loading";
    loading.setAttribute("role", "status");
    loading.setAttribute("aria-label", "Loading");
    text.appendChild(loading);

    const responseDiv = document.createElement("div");
    text.appendChild(responseDiv);

    let hasFirstToken = false;

    return (content) => {
        if (!hasFirstToken && content) {
            hasFirstToken = true;
            loading.remove();
        }
        responseDiv.innerHTML = formatResponseToHTML(content || "");
        chatContainer.scrollTo({ top: chatContainer.scrollHeight, behavior: "smooth" });
    };
}
function createChatBox(html, classes){

    let Box = document.createElement("div")
    Box.innerHTML = html
    Box.classList.add(classes)
    return Box
};
let RememberingCurrentChat = "";
let currentChat = "";

function buildCurrentChatSummary(message, responses) {
    return `promt:${message}\nreponses\n` +
        `Gimini:${responses.gemini ?? null}\n` +
        `openai: ${responses.openai ?? null}\n` +
        `deepSeek: ${responses.deepSeek ?? null}`;
}

async function handleChatResponse(message, models) {
    try {
        contextChats = await getChatContextOnce();
        // Generate chat context
        let fullChat = contextChats.slice(0,3).map(chatSet =>
            chatSet.chats.map(chat => `User: ${chat.message}\nai: ${chat.response}\n\n`).join("")
        ).join("");
        if (fullChat) {
            fullChat += `# This is for context # :- Read all user and AI chat history, make 
            relationships between them, and respond considering the current user as the previous user.\n`;
        }
        fullChat += `#this is current session conversation# :- ${RememberingCurrentChat}, during answer use 
                    current session conversation and use context if needed.\n`;
        

        user.previousChat = fullChat || "";
        user.message = message;

        let userHtml = `
            <div class="user-chat-area">
                ${message}
                ${user.file?.data ? `<img src="data:${user.file.mime_type};base64,${user.file.data}" class="choosingImg" />` : ""}
            </div>`;

        promt.value = "";
        let userChatBox = createChatBox(userHtml, "user-chat-box");
        chatSection.appendChild(userChatBox);

        setTimeout(async () => {
            let responses = {};

            const loadingHtml = (modelName) => `
                <div class="ai-chat-area">
                    <h4>${modelName}</h4>
                    <img src="animation/Animation - 1737272179442.gif" alt="loading img">
                </div>`;

            let chatBoxes = {};
            imgbtn.src = imgsrc
            let aidata, openai, deepSeek;
            let compareResponse = null;
           
            if(models[0].checked && models[1].checked || 
            models[0].checked && models[2].checked || 
            models[1].checked && models[2].checked )
            {
               toggle.style.display = "block"
            }
            if(!toggle.checked){
            // Create chat boxes for selected models with loading indicators
            if (models[0]?.checked) {
                chatBoxes["Gemini"] = createChatBox(loadingHtml("Gemini"), "ai-chat-box");
                chatSection.appendChild(chatBoxes["Gemini"]);
            }
            if (models[1]?.checked) {
                chatBoxes["OpenAI"] = createChatBox(loadingHtml("OpenAI"), "ai-chat-box");
                chatSection.appendChild(chatBoxes["OpenAI"]);
            }
            if (models[2]?.checked) {
                chatBoxes["DeepSeek"] = createChatBox(loadingHtml("DeepSeek"), "ai-chat-box");
                chatSection.appendChild(chatBoxes["DeepSeek"]);
            }

            // Fetch responses from selected models
            const streamGimini = async () => {
                if (!models[0].checked) return null;
                const streamUpdater = startStreamingChatBox(chatBoxes["Gemini"], "Gemini");
                return getGiminiStreamResponse(fullChat, message, streamUpdater);
            };

            const streamOpenAi = async () => {
                if (!models[1].checked) return null;
                const streamUpdater = startStreamingChatBox(chatBoxes["OpenAI"], "ChatGPT");
                return getOpenAiStreamResponse(fullChat, message, streamUpdater);
            };

            const streamDeepSeek = async () => {
                if (!models[2].checked) return null;
                const streamUpdater = startStreamingChatBox(chatBoxes["DeepSeek"], "DeepSeek");
                return getDeepSeekStreamResponse(fullChat, message, streamUpdater);
            };

            [aidata, openai, deepSeek] = await Promise.all([
                streamGimini(),
                streamOpenAi(),
                streamDeepSeek()
            ]);

            // Update chat boxes with responses
            if (aidata) {
                if (!user.title) user.title = await getGiminiResponse(null, aidata, true);
                console.log(user.title)
            }
            if (openai) {
                if (!user.title) user.title = await getOpenAiResponse(null, openai, true);
            }
            if (deepSeek) {
                console.log(deepSeek)
                if (!user.title) user.title = await getDeepSeekResponse(null, deepSeek, true);
            }
            currentChat = buildCurrentChatSummary(user.message, {
                gemini: aidata,
                openai,
                deepSeek,
            });
            }
            else{
                let comparePrompt = `compare this different ai responses in context based on`;
                userInput.ariaPlaceholder = "compare this different ai responses based on...";
                console.log("Switch is ON");
                const compareContext = currentChat || fullChat;
                const compareMessage = `${comparePrompt} ${message}`;
                if (models[0].checked) {
                    chatBoxes["Gemini"] = createChatBox(loadingHtml("Gemini"), "ai-chat-box");
                    chatSection.appendChild(chatBoxes["Gemini"]);
                    const streamUpdater = startStreamingChatBox(chatBoxes["Gemini"], "Gemini");
                    compareResponse = await getGiminiStreamResponse(compareContext, compareMessage, streamUpdater);
                    if (!user.title && compareResponse) user.title = await getGiminiResponse(null, compareResponse, true);

                } else if (models[1].checked) {
                    chatBoxes["OpenAI"] = createChatBox(loadingHtml("OpenAI"), "ai-chat-box");
                    chatSection.appendChild(chatBoxes["OpenAI"]);
                    const streamUpdater = startStreamingChatBox(chatBoxes["OpenAI"], "ChatGPT");
                    compareResponse = await getOpenAiStreamResponse(compareContext, compareMessage, streamUpdater);
                    if (!user.title && compareResponse) user.title = await getOpenAiResponse(null, compareResponse, true);

                } else if (models[2].checked) {
                    chatBoxes["DeepSeek"] = createChatBox(loadingHtml("DeepSeek"), "ai-chat-box");
                    chatSection.appendChild(chatBoxes["DeepSeek"]);
                    const streamUpdater = startStreamingChatBox(chatBoxes["DeepSeek"], "DeepSeek");
                    compareResponse = await getDeepSeekStreamResponse(compareContext, compareMessage, streamUpdater);
                    if (!user.title && compareResponse) user.title = await getDeepSeekResponse(null, compareResponse, true);
                }
            }
           
            const userId = "<%= userdata.userId %>";
            const username = "<%= userdata.username %>";
            const aiResponseList = !toggle.checked
                ? [aidata, openai, deepSeek].filter(Boolean)
                : (compareResponse ? [compareResponse] : []);
            await saveChat(userId, username, user.message, aiResponseList, user.title, currentChatId);

        }, 600);
    } catch (err) {
        console.error(err);
    }
}


